# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://omniverse:secret@localhost:5432/omniversedb"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-vault"
JWT_EXPIRES_IN="24h"

# ─── HashiCorp Vault ──────────────────────────────────────────────────────────
VAULT_ADDR="http://127.0.0.1:8200"
VAULT_TOKEN="dev-only-root-token"

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN="http://localhost:5173"

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
